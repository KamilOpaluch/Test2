def load_config(config_filename='config.txt'):
    script_dir = os.path.dirname(os.path.abspath(__file__))
    config_path = os.path.join(script_dir, config_filename)
    config = {}
    with open(config_path, 'r') as f:
        for line in f:
            if '=' in line:
                key, value = line.strip().split('=', 1)
                config[key] = value
    return config

config = load_config()

ACCESS_DB_PATH = config['ACCESS_DB_PATH']
EXCEL_FILE_PATH = os.path.join(os.path.dirname(os.path.abspath(__file__)), 'MCC_Template.xlsx')
ORACLE_USER = config['ORACLE_USER']
ORACLE_PASSWORD = config['ORACLE_PASSWORD']
