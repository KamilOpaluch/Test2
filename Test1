def run_script():
    selected_date = calendar.get_date().strftime('%d-%b-%y').upper()
    selected_entity = entity_var.get()

    access_conn = pyodbc.connect(ACCESS_CONN_STR)

    if selected_entity == 'CGME ECB':
        mcc_df = pd.read_sql('SELECT * FROM Mapping_PnL_ECB', access_conn)
    elif selected_entity == 'CGME PRA':
        mapping_pnl_df = pd.read_sql('SELECT * FROM Mapping_PnL', access_conn)
        mcc_df = mapping_pnl_df[mapping_pnl_df['Legal_Entity'] == 'CGME']
    else:
        mapping_pnl_df = pd.read_sql('SELECT * FROM Mapping_PnL', access_conn)
        mcc_df = mapping_pnl_df[mapping_pnl_df['Legal_Entity'] == selected_entity]

    access_conn.close()

    excel_path = 'input.xlsx'
    mcc_template_df = pd.read_excel(excel_path, sheet_name='INPUT', usecols=[0])
    mcc_template_values = tuple(mcc_template_df.iloc[:, 0].dropna().unique())

    dsn = cx_Oracle.makedsn("your_host", 1521, sid="your_sid")
    oracle_conn = cx_Oracle.connect(user="your_user", password="your_pass", dsn=dsn)
    cursor = oracle_conn.cursor()

    level_12_values = ['S2' + str(val) for val in mcc_df['LEVEL_12'].dropna().unique()]
    oracle_old_df = fetch_oracle_data_by_level_12(cursor, level_12_values, selected_date)
    oracle_old_df['LEVEL_12'] = oracle_old_df['LEVEL_12'].str[2:]
    old_mcc_df = pd.merge(mcc_df, oracle_old_df, on='LEVEL_12', how='left')

    new_level_10s = list(mcc_template_values)
    new_mcc_df = fetch_oracle_data_by_level_10(cursor, new_level_10s, selected_date)

    cursor.close()
    oracle_conn.close()

    insert_df = new_mcc_df[['LEVEL_10', 'GOC_ID', 'LEVEL_12', 'LEVEL_4', 'LEVEL_6', 'LEVEL_8', 'LEVEL_9']].copy()

    def find_desk(row):
        for level in ['LEVEL_9', 'LEVEL_8', 'LEVEL_6', 'LEVEL_4']:
            match = old_mcc_df[old_mcc_df[level] == row[level]]
            if not match.empty:
                return match['DESK_LEVEL'].values[0]
        return ''

    insert_df['DESK_LEVEL'] = insert_df.apply(find_desk, axis=1)
    insert_df['LEGAL_ENTITY'] = 'CGME' if selected_entity == 'CGME PRA' else selected_entity
    insert_df = insert_df[['LEVEL_10', 'GOC_ID', 'LEVEL_12', 'LEVEL_4', 'LEVEL_6', 'LEVEL_8', 'LEVEL_9', 'DESK_LEVEL', 'LEGAL_ENTITY']]

    with pd.ExcelWriter(excel_path, mode='a', engine='openpyxl', if_sheet_exists='replace') as writer:
        new_mcc_df.to_excel(writer, sheet_name='NEW_MCC', index=False)
        old_mcc_df.to_excel(writer, sheet_name='OLD_MCC', index=False)
        insert_df.to_excel(writer, sheet_name='INSERT', index=False)

    print("Process completed successfully.")

