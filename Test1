import win32com.client
import openpyxl
import os

def export_queries_to_excel(access_db_path, excel_path):
    # Open Access Application
    access_app = win32com.client.Dispatch("Access.Application")
    access_app.Visible = False
    access_app.OpenCurrentDatabase(access_db_path)

    # Get query definitions
    db = access_app.CurrentDb()
    queries = db.QueryDefs

    # Prepare Excel
    wb = openpyxl.Workbook()
    ws = wb.active
    ws.title = "Queries"
    ws.append(["Query Name", "SQL"])

    for q in queries:
        # Skip system/internal queries
        if q.Name.startswith("~") or q.Name.startswith("MSys"):
            continue
        try:
            ws.append([q.Name, q.SQL])
        except Exception as e:
            ws.append([q.Name, f"ERROR: {e}"])

    # Save Excel
    wb.save(excel_path)

    # Clean up
    access_app.CloseCurrentDatabase()
    access_app.Quit()

# Example usage
access_db = r"C:\path\to\your\database.accdb"
excel_output = r"C:\path\to\output\queries.xlsx"
export_queries_to_excel(access_db, excel_output)

print("Export complete!")
