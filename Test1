import cx_Oracle
import pandas as pd
from openpyxl.utils.exceptions import IllegalCharacterError

# === Connection setup ===
dsn = cx_Oracle.makedsn("host", port, sid="your_sid")  # or service_name="..."
conn = cx_Oracle.connect(user="your_user", password="your_password", dsn=dsn)
cursor = conn.cursor()

# === Find matching tables ===
cursor.execute("""
    SELECT table_name 
    FROM all_tables 
    WHERE table_name LIKE '%ISSUER_RISK%' 
      AND table_name NOT LIKE '%RETIRED%'
""")
tables = [row[0] for row in cursor.fetchall()]
print(f"Found {len(tables)} matching tables.")

# === Prepare Excel file ===
excel_path = "issuer_risk_report.xlsx"
with pd.ExcelWriter(excel_path, engine='openpyxl') as writer:
    # Sheet with table list
    pd.DataFrame(tables, columns=["Matching_Tables"]).to_excel(writer, sheet_name="Table_List", index=False)

    for table in tables:
        # Get column names
        cursor.execute("""
            SELECT column_name 
            FROM all_tab_columns 
            WHERE table_name = :table
        """, {"table": table})
        columns = [r[0] for r in cursor.fetchall()]

        # Get one sample value per column
        data = []
        for col in columns:
            try:
                cursor.execute(f'SELECT "{col}" FROM "{table}" WHERE ROWNUM = 1')
                val = cursor.fetchone()
                example = val[0] if val else None
            except Exception as e:
                example = f"Error: {e}"
            data.append((col, example))

        df = pd.DataFrame(data, columns=["Column_name", "Example_value"])
        safe_sheet = table[:31]
        try:
            df.to_excel(writer, sheet_name=safe_sheet, index=False)
        except IllegalCharacterError:
            cleaned = ''.join(c if c.isalnum() else '_' for c in safe_sheet)
            df.to_excel(writer, sheet_name=cleaned, index=False)

# === Cleanup ===
cursor.close()
conn.close()
print(f"Excel saved as: {excel_path}")
