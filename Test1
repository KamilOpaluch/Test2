import os
import tkinter as tk
from tkinter import ttk, messagebox
from tkinter.filedialog import asksaveasfilename
import pandas as pd
import requests
from datetime import datetime, timedelta
import sqlite3
from io import BytesIO
from workdays import workday

# === CONFIGURATION === #
links_dict = {
    "https://example.com/shared/{date}/report1.xlsx": "report1_df",
    "https://example.com/shared/{date}/report2.xlsx": "report2_df",
    # Add more links and variable names here
}

DB_FILE = "report_data.db"
LOG_FILE = "download_logs.txt"

# === BUSINESS DAY FUNCTIONS === #
def get_business_day(offset):
    today = datetime.today().date()
    return workday(today, offset).strftime("%Y%d%m")

# === DATA HANDLING === #
def download_and_parse_excel(link, date_str, table_prefix):
    url = link.format(date=date_str)
    try:
        response = requests.get(url)
        response.raise_for_status()
        xls = pd.ExcelFile(BytesIO(response.content))

        valid_sheets = [s for s in xls.sheet_names if s.lower() != "selectioncriteria"]
        if not valid_sheets:
            raise ValueError("Only SelectionCriteria found")

        df = pd.read_excel(xls, sheet_name=valid_sheets[0], skiprows=2)
        if df.dropna(how="all").shape[0] == 0:
            raise ValueError("No data rows")

        return df, url
    except Exception as e:
        with open(LOG_FILE, "a") as log:
            log.write(f"{table_prefix}_{os.path.basename(link)}: {url} - {e}\n")
        return None, url

# === DATABASE === #
def save_to_db(df, table_name):
    conn = sqlite3.connect(DB_FILE)
    df.to_sql(table_name, conn, if_exists="replace", index=False)
    conn.close()

# === GUI === #
class ExcelDownloaderApp:
    def __init__(self, root):
        self.root = root
        self.root.title("Excel Downloader Tool")

        today_t2 = get_business_day(-2)
        self.date_var = tk.StringVar(value=today_t2)

        tk.Label(root, text="Select T-2 Date (yyyyddmm):").pack()
        self.date_entry = tk.Entry(root, textvariable=self.date_var)
        self.date_entry.pack()

        self.check_vars = {}
        self.check_all_var = tk.IntVar()

        tk.Checkbutton(root, text="Select/Deselect All", variable=self.check_all_var, command=self.toggle_all).pack()

        for url in links_dict:
            var = tk.IntVar(value=1)
            self.check_vars[url] = var
            tk.Checkbutton(root, text=url, variable=var, wraplength=400).pack(anchor="w")

        tk.Button(root, text="Run", command=self.run_download).pack(pady=10)

    def toggle_all(self):
        for var in self.check_vars.values():
            var.set(self.check_all_var.get())

    def run_download(self):
        t2_date = self.date_var.get()
        try:
            datetime.strptime(t2_date, "%Y%d%m")
        except ValueError:
            messagebox.showerror("Invalid Date", "Enter date in yyyyddmm format.")
            return

        t3_date = workday(datetime.strptime(t2_date, "%Y%d%m").date(), -1).strftime("%Y%d%m")

        if os.path.exists(LOG_FILE):
            os.remove(LOG_FILE)

        all_successful = True
        for url, var in self.check_vars.items():
            if var.get():
                for prefix, d in zip(["T2", "T3"], [t2_date, t3_date]):
                    df, attempted_url = download_and_parse_excel(url, d, prefix)
                    if df is not None:
                        table_name = f"{prefix}_{os.path.basename(url).replace('.xlsx','')}"
                        save_to_db(df, table_name)
                    else:
                        all_successful = False

        if all_successful:
            messagebox.showinfo("Success", "All data successfully loaded.")
        else:
            if messagebox.askyesno("Missing Data", "Some data were missing or empty. Open logs?"):
                os.startfile(LOG_FILE)

# === MAIN === #
if __name__ == "__main__":
    root = tk.Tk()
    app = ExcelDownloaderApp(root)
    root.mainloop()
