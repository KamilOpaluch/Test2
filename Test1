import pyodbc
import os

def get_table_sizes(database_path):
    conn_str = (
        r'DRIVER={Microsoft Access Driver (*.mdb, *.accdb)};'
        f'DBQ={database_path};'
    )
    
    conn = pyodbc.connect(conn_str)
    cursor = conn.cursor()

    # Get list of all user tables
    tables = [
        row.table_name
        for row in cursor.tables()
        if row.table_type == 'TABLE'
    ]

    table_info = []

    for table in tables:
        try:
            # Count rows
            cursor.execute(f"SELECT COUNT(*) FROM [{table}]")
            row_count = cursor.fetchone()[0]

            # Estimate table size by reading all data
            cursor.execute(f"SELECT * FROM [{table}]")
            rows = cursor.fetchall()
            size_bytes = sum([sum(len(str(value)) for value in row) for row in rows])
            size_mb = round(size_bytes / (1024 * 1024), 2)

            table_info.append((table, size_mb, row_count))
        except Exception as e:
            print(f"Error reading table {table}: {e}")

    conn.close()

    # Sort by size descending
    table_info.sort(key=lambda x: x[1], reverse=True)

    return table_info

# Example usage
database_path = r'C:\path\to\your\database.accdb'
tables = get_table_sizes(database_path)

print(f"{'Table':40} {'Size (MB)':>10} {'Rows':>10}")
print("-" * 60)
for table, size, rows in tables:
    print(f"{table:40} {size:10.2f} {rows:10}")
