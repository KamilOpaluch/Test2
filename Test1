import ttkbootstrap as tb
from ttkbootstrap.constants import *
from tkinter import messagebox
from tkcalendar import DateEntry
import pandas as pd
import pyodbc
import cx_Oracle
import threading
import os
import subprocess

# --- Configuration ---
def load_config(config_filename='config.txt'):
    script_dir = os.path.dirname(os.path.abspath(__file__))
    config_path = os.path.join(script_dir, config_filename)
    config = {}
    with open(config_path, 'r') as f:
        for line in f:
            if '=' in line:
                key, value = line.strip().split('=', 1)
                config[key] = value
    return config

config = load_config()

ACCESS_DB_PATH = config['ACCESS_DB_PATH']
ORACLE_USER = config['ORACLE_USER']
ORACLE_PASSWORD = config['ORACLE_PASSWORD']
ORACLE_HOST = config['ORACLE_HOST']
ORACLE_PORT = config['ORACLE_PORT']
ORACLE_SERVICE = config['ORACLE_SERVICE']

ACCESS_CONN_STR = (
    r'DRIVER={Microsoft Access Driver (*.mdb, *.accdb)};'
    f'DBQ={ACCESS_DB_PATH};'
)

EXCEL_FILE_PATH = os.path.join(os.path.dirname(os.path.abspath(__file__)), 'MCC_Template.xlsx')

steps_done = {}
spinner_running = False

# --- Utility Functions ---
def log_debug(message):
    debug_console.config(state='normal')
    debug_console.insert('end', f"{message}\n")
    debug_console.see('end')
    debug_console.config(state='disabled')

def fetch_oracle_data(cursor, columns, where_column, values, selected_date):
    batch_size = 900
    all_batches = []
    for i in range(0, len(values), batch_size):
        batch = values[i:i + batch_size]
        placeholders = ','.join([f':{i+1}' for i in range(len(batch))])
        query = f'''
            SELECT {', '.join(columns)}
            FROM BUS_HIERARCHY
            WHERE {where_column} IN ({placeholders})
            AND AS_OF = :{len(batch) + 1}'''
        params = list(batch) + [selected_date]
        cursor.execute(query, params)
        all_batches.extend(cursor.fetchall())
    return pd.DataFrame(all_batches, columns=columns)

def update_checkbox(step):
    steps_done[step][0].set(True)

def clear_checkboxes_and_log():
    for var, _ in steps_done.values():
        var.set(False)
    debug_console.config(state='normal')
    debug_console.delete('1.0', 'end')
    debug_console.config(state='disabled')

def start_spinner():
    global spinner_running
    spinner_running = True
    rotate_spinner()

def stop_spinner():
    global spinner_running
    spinner_running = False

def rotate_spinner():
    if spinner_running:
        current = spinner_label['text']
        next_frame = {'|': '/', '/': '-', '-': '\\', '\\': '|'}[current]
        spinner_label.config(text=next_frame)
        root.after(100, rotate_spinner)

def open_excel_template():
    try:
        subprocess.Popen(['start', EXCEL_FILE_PATH], shell=True)
    except Exception as e:
        messagebox.showerror("Error opening file", str(e))
        log_debug(f"Error opening Excel: {str(e)}")

def run_script():
    try:
        clear_checkboxes_and_log()
        start_spinner()
        log_debug("Starting processing...")
        selected_date = calendar.entry.get_date().strftime('%d-%b-%y').upper()
        selected_entity = entity_var.get()

        update_checkbox('db_open')
        access_conn = pyodbc.connect(ACCESS_CONN_STR)

        if selected_entity == 'CGME ECB':
            mcc_df = pd.read_sql('SELECT * FROM Mapping_PnL_ECB', access_conn)
        elif selected_entity == 'CGME PRA':
            mapping_pnl_df = pd.read_sql('SELECT * FROM Mapping_PnL', access_conn)
            mcc_df = mapping_pnl_df[mapping_pnl_df['LEGAL_ENTITY'] == 'CGME']
        else:
            mapping_pnl_df = pd.read_sql('SELECT * FROM Mapping_PnL', access_conn)
            mcc_df = mapping_pnl_df[mapping_pnl_df['LEGAL_ENTITY'] == selected_entity]

        access_conn.close()
        update_checkbox('access_loaded')
        log_debug("Loaded Access data.")

        mcc_template_df = pd.read_excel(EXCEL_FILE_PATH, sheet_name='INPUT', usecols=[0])
        mcc_template_values = tuple(mcc_template_df.iloc[:, 0].dropna().unique())
        update_checkbox('excel_loaded')
        log_debug("Loaded Excel input.")

        dsn = cx_Oracle.makedsn(ORACLE_HOST, ORACLE_PORT, service_name=ORACLE_SERVICE)
        oracle_conn = cx_Oracle.connect(user=ORACLE_USER, password=ORACLE_PASSWORD, dsn=dsn)
        cursor = oracle_conn.cursor()

        LEVEL_12_values = ['S2' + str(val) for val in mcc_df['LEVEL_12'].dropna().unique()]
        oracle_old_df = fetch_oracle_data(cursor, ['LEVEL_12', 'LEVEL_4', 'LEVEL_6', 'LEVEL_8', 'LEVEL_9'], 'LEVEL_12', LEVEL_12_values, selected_date)
        oracle_old_df['LEVEL_12'] = oracle_old_df['LEVEL_12'].str[2:]
        old_mcc_df = pd.merge(mcc_df, oracle_old_df, on='LEVEL_12', how='left')

        new_mcc_df = fetch_oracle_data(cursor, ['LEVEL_10', 'GOC_ID', 'LEVEL_12', 'LEVEL_4', 'LEVEL_6', 'LEVEL_8', 'LEVEL_9'], 'LEVEL_10', list(mcc_template_values), selected_date)

        cursor.close()
        oracle_conn.close()
        update_checkbox('oracle_fetched')
        log_debug("Fetched Oracle data.")

        insert_df = new_mcc_df.copy()

        def find_desk(row):
            for level in ['LEVEL_9', 'LEVEL_8', 'LEVEL_6', 'LEVEL_4']:
                match = old_mcc_df[old_mcc_df[level] == row[level]]
                if not match.empty:
                    return match['DESK_LEVEL'].values[0], level
            return '', ''

        results = insert_df.apply(find_desk, axis=1)
        insert_df['DESK_LEVEL'] = results.apply(lambda x: x[0])
        insert_df['MATCHED_ON_LEVEL'] = results.apply(lambda x: x[1])
        insert_df['LEVEL12_EXISTS'] = insert_df['LEVEL_12'].isin(old_mcc_df['LEVEL_12'])
        insert_df['LEGAL_ENTITY'] = 'CGME' if selected_entity == 'CGME PRA' else selected_entity

        insert_df['LEVEL_12'] = insert_df['LEVEL_12'].str.replace('^S2', '', regex=True)
        insert_df = insert_df[['LEVEL_10', 'GOC_ID', 'LEVEL_12', 'LEVEL_4', 'LEVEL_6', 'LEVEL_8', 'LEVEL_9', 'DESK_LEVEL', 'MATCHED_ON_LEVEL', 'LEVEL12_EXISTS', 'LEGAL_ENTITY']]

        with pd.ExcelWriter(EXCEL_FILE_PATH, mode='a', engine='openpyxl', if_sheet_exists='replace') as writer:
            new_mcc_df.to_excel(writer, sheet_name='NEW_MCC', index=False)
            old_mcc_df.to_excel(writer, sheet_name='OLD_MCC', index=False)
            insert_df.to_excel(writer, sheet_name='INSERT', index=False)

        update_checkbox('saved_excel')
        log_debug("Saved Excel file successfully.")
        messagebox.showinfo("Success", "Process completed successfully.")

    except Exception as e:
        log_debug(f"Error: {str(e)}")
        messagebox.showerror("Error", str(e))
    finally:
        stop_spinner()

# --- GUI ---
root = tb.Window(themename="darkly")
root.title("MCC Data Processor")
root.geometry("900x600")

messagebox.showinfo("Startup Info", "Ensure Access database is open.\nUpdate INPUT sheet in MCC_Template.xlsx before running.")

frame_top = tb.Frame(root)
frame_top.pack(pady=15)

frame_buttons = tb.Frame(root)
frame_buttons.pack(pady=10)

frame_checklist = tb.LabelFrame(root, text="Processing Steps")
frame_checklist.pack(pady=10)

frame_console = tb.LabelFrame(root, text="Debug Console")
frame_console.pack(fill=BOTH, expand=True, padx=20, pady=10)

# Top section
calendar_label = tb.Label(frame_top, text="Select Date:")
calendar_label.grid(row=0, column=0, padx=5)
calendar = tb.DateEntry(frame_top, bootstyle="info")
calendar.grid(row=0, column=1, padx=5)

entity_label = tb.Label(frame_top, text="Select Entity:")
entity_label.grid(row=0, column=2, padx=5)
entity_var = tb.StringVar()
dropdown = tb.Combobox(frame_top, textvariable=entity_var, values=['CEP', 'CGML', 'CGME PRA', 'CGME ECB'], bootstyle="dark")
dropdown.grid(row=0, column=3, padx=5)

# Buttons + Spinner
run_button = tb.Button(frame_buttons, text="Run", bootstyle="success-outline", command=lambda: threading.Thread(target=run_script, daemon=True).start())
run_button.grid(row=0, column=0, padx=5)

spinner_label = tb.Label(frame_buttons, text='|', font=("Courier New", 22))
spinner_label.grid(row=0, column=1, padx=10)

excel_button = tb.Button(frame_buttons, text="Open MCC Template", bootstyle="info-outline", command=open_excel_template)
excel_button.grid(row=0, column=2, padx=5)

# Checklist
steps = ['db_open', 'access_loaded', 'excel_loaded', 'oracle_fetched', 'saved_excel']
for idx, step in enumerate(steps):
    var = tb.BooleanVar()
    cb = tb.Checkbutton(frame_checklist, text=step.replace('_', ' ').capitalize(), variable=var, bootstyle="success-round-toggle toolbutton")
    cb.grid(row=idx, column=0, sticky='w', padx=10)
    cb.config(state='disabled')
    steps_done[step] = (var, cb)

# Debug Console
debug_console = tb.ScrolledText(frame_console, height=10, font=("Consolas", 10), wrap='word')
debug_console.pack(fill=BOTH, expand=True)
debug_console.config(state='disabled')

root.mainloop()
