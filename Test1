import cx_Oracle
import pandas as pd
from openpyxl.utils.exceptions import IllegalCharacterError

# === CONFIGURATION ===
dsn = cx_Oracle.makedsn("host", port, sid="your_sid")  # or use service_name="..."
conn = cx_Oracle.connect(user="your_user", password="your_password", dsn=dsn)
schema = 'YOUR_SCHEMA'  # <-- Use your schema name in UPPERCASE

# === GET TABLES MATCHING CRITERIA ===
cursor = conn.cursor()
cursor.execute(f"""
    SELECT table_name 
    FROM all_tables 
    WHERE owner = :owner
      AND UPPER(table_name) LIKE '%ISSUER_RISK%'
      AND UPPER(table_name) NOT LIKE '%RETIRED%'
""", [schema.upper()])

tables = [row[0] for row in cursor.fetchall()]
print(f"Found {len(tables)} matching tables.")

# === WRITE TO EXCEL ===
excel_path = "issuer_risk_report.xlsx"
with pd.ExcelWriter(excel_path, engine='openpyxl') as writer:
    # Summary sheet
    pd.DataFrame(tables, columns=["Matching_Tables"]).to_excel(writer, sheet_name="Table_List", index=False)

    for table in tables:
        # Get column names
        cursor.execute("""
            SELECT column_name 
            FROM all_tab_columns 
            WHERE table_name = :table AND owner = :owner
        """, [table, schema.upper()])
        columns = [row[0] for row in cursor.fetchall()]

        data = []
        for col in columns:
            try:
                cursor.execute(f'SELECT "{col}" FROM {schema}."{table}" WHERE ROWNUM = 1')
                val = cursor.fetchone()
                example = val[0] if val else None
            except Exception as e:
                example = f"Error: {str(e)}"
            data.append((col, example))

        df = pd.DataFrame(data, columns=["Column_name", "Example_value"])
        # Ensure sheet name is valid
        safe_sheet_name = table[:31].replace(' ', '_')
        try:
            df.to_excel(writer, sheet_name=safe_sheet_name, index=False)
        except IllegalCharacterError:
            safe_sheet_name = ''.join(c if c.isalnum() else '_' for c in safe_sheet_name)
            df.to_excel(writer, sheet_name=safe_sheet_name, index=False)

cursor.close()
conn.close()
print(f"Excel report saved to: {excel_path}")
