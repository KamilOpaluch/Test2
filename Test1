import cx_Oracle
import pandas as pd

# Connect to Oracle
dsn = cx_Oracle.makedsn("host", port, sid="your_sid")  # or use service_name="..."
conn = cx_Oracle.connect(user="your_user", password="your_password", dsn=dsn)
cursor = conn.cursor()

# Find all tables with "ISSUER" in their names (case-insensitive)
cursor.execute("""
    SELECT table_name 
    FROM all_tables 
    WHERE table_name LIKE '%ISSUER%' AND owner = UPPER(:owner)
""", owner='YOUR_SCHEMA')  # replace with your schema
tables = [row[0] for row in cursor.fetchall()]

# Loop through each table and extract column names and example values
for table in tables:
    print(f"\nTable: {table}")
    
    # Get column names
    cursor.execute(f"""
        SELECT column_name 
        FROM all_tab_columns 
        WHERE table_name = :table
    """, table=table)
    columns = [row[0] for row in cursor.fetchall()]

    data = []
    for col in columns:
        try:
            cursor.execute(f'SELECT "{col}" FROM {table} WHERE ROWNUM = 1')
            val = cursor.fetchone()
            example = val[0] if val else None
        except Exception as e:
            example = f"Error: {e}"
        data.append((col, example))

    df = pd.DataFrame(data, columns=["Column_name", "Example_value"])
    print(df)

# Cleanup
cursor.close()
conn.close()
