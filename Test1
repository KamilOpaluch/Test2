import tkinter as tk
from tkinter import ttk
from tkcalendar import DateEntry
import pandas as pd
import pyodbc
import cx_Oracle
from datetime import datetime
import os

# Assume the Access database is already open using a full connection string
ACCESS_DB_PATH = r'C:\path\to\CGML_Backtesting v1.accdb'
ACCESS_CONN_STR = (
    r'DRIVER={Microsoft Access Driver (*.mdb, *.accdb)};'
    f'DBQ={ACCESS_DB_PATH};'
    r'PWD=your_password_here;'  # if needed
)

def run_script():
    selected_date = calendar.get_date().strftime('%d-%b-%y').upper()
    selected_entity = entity_var.get()

    # Step 1: Use Access DB full connection string
    access_conn = pyodbc.connect(ACCESS_CONN_STR)

    mapping_pnl_df = pd.read_sql('SELECT * FROM Mapping_PnL', access_conn)
    mapping_pnl_ecb_df = pd.read_sql('SELECT * FROM Mapping_PnL_ECB', access_conn)
    mapping_pnl_ecb_df['Legal_Entity'] = mapping_pnl_ecb_df['Legal_Entity'].replace('CGME', 'CGME ECB')
    mcc_df = pd.concat([mapping_pnl_df, mapping_pnl_ecb_df], ignore_index=True)

    access_conn.close()

    # Step 2: Read MCC_Template from Excel INPUT sheet
    excel_path = 'input.xlsx'
    mcc_template_df = pd.read_excel(excel_path, sheet_name='INPUT', usecols=[0])
    mcc_template_values = tuple(mcc_template_df.iloc[:, 0].dropna().unique())

    # Step 3: Query Oracle for LEVEL_12 values from Access to get LEVEL_4,6,8
    dsn = cx_Oracle.makedsn("your_host", 1521, sid="your_sid")
    oracle_conn = cx_Oracle.connect(user="your_user", password="your_pass", dsn=dsn)

    level_12_values = tuple(mcc_df['LEVEL_12'].dropna().unique())
    placeholders = ','.join([f':{i+1}' for i in range(len(level_12_values))])
    query_old = f'''
        SELECT LEVEL_12, LEVEL_4, LEVEL_6, LEVEL_8
        FROM BUS_HIERARCHY
        WHERE LEVEL_12 IN ({placeholders})
        AND AS_OF = :{len(level_12_values) + 1}'''

    cursor = oracle_conn.cursor()
    params_old = list(level_12_values) + [selected_date]
    cursor.execute(query_old, params_old)
    results_old = cursor.fetchall()
    columns_old = ['LEVEL_12', 'LEVEL_4', 'LEVEL_6', 'LEVEL_8']
    oracle_old_df = pd.DataFrame(results_old, columns=columns_old)

    # Merge old MCC with oracle level info
    old_mcc_df = pd.merge(mcc_df, oracle_old_df, on='LEVEL_12', how='left')

    # Step 4: Query Oracle for new MCC values based on template LEVEL_10
    new_level_10s = tuple(mcc_template_values)
    placeholders_new = ','.join([f':{i+1}' for i in range(len(new_level_10s))])
    query_new = f'''
        SELECT LEVEL_10, GOC_ID, LEVEL_12, LEVEL_4, LEVEL_6, LEVEL_8
        FROM BUS_HIERARCHY
        WHERE LEVEL_10 IN ({placeholders_new})
        AND AS_OF = :{len(new_level_10s) + 1}'''

    params_new = list(new_level_10s) + [selected_date]
    cursor.execute(query_new, params_new)
    results_new = cursor.fetchall()
    columns_new = ['LEVEL_10', 'GOC_ID', 'LEVEL_12', 'LEVEL_4', 'LEVEL_6', 'LEVEL_8']
    new_mcc_df = pd.DataFrame(results_new, columns=columns_new)

    cursor.close()
    oracle_conn.close()

    # Step 5: Create INSERT sheet by matching on LEVEL_4, 6, 8 and extracting DESK_LEVEL from old_mcc_df
    insert_df = new_mcc_df[['LEVEL_10', 'GOC_ID', 'LEVEL_12', 'LEVEL_4', 'LEVEL_6', 'LEVEL_8']].copy()

    def find_desk(row):
        match = old_mcc_df[
            (old_mcc_df['LEVEL_4'] == row['LEVEL_4']) &
            (old_mcc_df['LEVEL_6'] == row['LEVEL_6']) &
            (old_mcc_df['LEVEL_8'] == row['LEVEL_8'])
        ]
        return match['DESK_LEVEL'].values[0] if not match.empty else ''

    insert_df['DESK_LEVEL'] = insert_df.apply(find_desk, axis=1)
    insert_df['LEGAL_ENTITY'] = selected_entity
    insert_df = insert_df[['LEVEL_10', 'GOC_ID', 'LEVEL_12', 'DESK_LEVEL', 'LEGAL_ENTITY']]

    # Step 6: Write to Excel (clear all sheets except INPUT)
    with pd.ExcelWriter(excel_path, mode='a', engine='openpyxl', if_sheet_exists='replace') as writer:
        new_mcc_df.to_excel(writer, sheet_name='NEW_MCC', index=False)
        old_mcc_df.to_excel(writer, sheet_name='OLD_MCC', index=False)
        insert_df.to_excel(writer, sheet_name='INSERT', index=False)

    print("Process completed successfully.")

# GUI
root = tk.Tk()
root.title("MCC Data Processor")

# Date picker
tk.Label(root, text="Select Date:").grid(row=0, column=0, padx=10, pady=5)
calendar = DateEntry(root, date_pattern='dd-mm-yyyy')
calendar.grid(row=0, column=1, padx=10, pady=5)

# Dropdown
tk.Label(root, text="Select Entity:").grid(row=1, column=0, padx=10, pady=5)
entity_var = tk.StringVar()
dropdown = ttk.Combobox(root, textvariable=entity_var)
dropdown['values'] = ('CEP', 'CGML', 'CGME PRA', 'CGME ECB')
dropdown.grid(row=1, column=1, padx=10, pady=5)

# Run button
run_button = tk.Button(root, text="Run", command=run_script)
run_button.grid(row=2, column=0, columnspan=2, pady=10)

root.mainloop()
