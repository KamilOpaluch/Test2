def fetch_oracle_data_by_level_12(cursor, level_12_values, selected_date):
    batch_size = 900
    all_batches = []

    for i in range(0, len(level_12_values), batch_size):
        batch = level_12_values[i:i + batch_size]
        placeholders = ','.join([f':{i+1}' for i in range(len(batch))])
        query = f'''
            SELECT LEVEL_12, LEVEL_4, LEVEL_6, LEVEL_8
            FROM BUS_HIERARCHY
            WHERE LEVEL_12 IN ({placeholders})
            AND AS_OF = :{len(batch) + 1}
        '''
        params = list(batch) + [selected_date]
        cursor.execute(query, params)
        batch_result = cursor.fetchall()
        all_batches.extend(batch_result)

    return pd.DataFrame(all_batches, columns=['LEVEL_12', 'LEVEL_4', 'LEVEL_6', 'LEVEL_8'])

